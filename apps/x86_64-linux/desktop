#!/usr/bin/env bash
set -eu

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Helper functions for Bitwarden access
have() { command -v "$1" >/dev/null 2>&1; }
have_docker() { command -v docker >/dev/null 2>&1; }

# Bitwarden CLI (bw) helpers for master password + 2FA method
ensure_bw() {
  if have bw; then
    return 0
  fi
  # Try to install bw using nix
  if have nix; then
    nix-shell -p bitwarden-cli --run "true"
    return 0
  fi
  return 1
}

bw_get_token() {
  local email="$1"
  local password="$2"
  local twofa_code="$3"
  
  # Login and get session
  BW_SESSION=$(bw login "$email" "$password" --raw)
  if [ $? -ne 0 ]; then
    return 1
  fi
  
  # Handle 2FA if needed
  if [[ "$BW_SESSION" == *"You must complete two-step login"* ]]; then
    BW_SESSION=$(bw login --method 0 --code "$twofa_code" --session "$BW_SESSION" --raw)
    if [ $? -ne 0 ]; then
      return 1
    fi
  fi
  
  # Unlock vault and get GitHub token
  BW_SESSION="$BW_SESSION" bw get item "GitHub Token" --raw | jq -r '.fields[] | select(.name=="token") | .value'
}

# Bitwarden Secrets Manager (bws) helpers for access token method
bws_cmd() {
  if have bws; then
    BWS_ACCESS_TOKEN="$BWS_ACCESS_TOKEN" bws "$@"
  elif have_docker; then
    docker run --rm -e BWS_ACCESS_TOKEN="$BWS_ACCESS_TOKEN" bitwarden/bws "$@"
  else
    echo "bws command not found" >&2
    return 127
  fi
}

ensure_bws() {
  if have bws || have_docker; then
    return 0
  fi
  # Try to install bws using nix
  if have nix; then
    nix-shell -p bitwarden-cli --run "true"
    return 0
  fi
  return 1
}

#commit

check_installer() {
  if [ -e /etc/NIXOS ]; then
    echo -e "\e[1;32mRunning in the NixOS installer environment.\e[0m"
  else
    echo -e "\e[1;31mNot running in the NixOS installer environment.\e[0m"
    exit 1
  fi
}

# Require UEFI for systemd-boot based installs. In Proxmox,
# set Firmware to OVMF (UEFI) and add an EFI Disk. See:
# https://nixos.wiki/wiki/Proxmox_Virtual_Environment
check_uefi_or_exit() {
  if [ ! -d /sys/firmware/efi ]; then
    echo -e "${YELLOW}UEFI firmware not detected.${NC}"
    echo -e "${YELLOW}This installer targets UEFI (systemd-boot).${NC}"
    echo -e "${CYAN}In Proxmox, set VM Firmware: 'OVMF (UEFI)' and add an EFI Disk, then reboot the installer.${NC}"
    echo -e "${CYAN}Docs: https://nixos.wiki/wiki/Proxmox_Virtual_Environment${NC}"
    exit 1
  fi
}

cleanup() {
  rm -rf nixos-config-main.zip nixos-config-main nixos-config nix-* nyx-*
}

download_config() {
  # Allow pinning a branch, tag, or commit SHA via NIX_REF; default to 'testing'
  NIX_REF=${NIX_REF:-testing}
  curl -LJ0 "https://github.com/xlrinn/nix/archive/${NIX_REF}.zip" -o nixos-config-main.zip
  unzip -q nixos-config-main.zip
  # Find extracted directory (nix-<refOrSha>) and enter
  SRC_DIR=$(find . -maxdepth 1 -type d -name "nix-*" | head -n1)
  if [ -z "$SRC_DIR" ] || [ ! -d "$SRC_DIR" ]; then
    echo -e "${RED}Error: Extracted directory not found after download.${NC}"
    exit 1
  fi
  cd "$SRC_DIR"
  echo -e "${GREEN}✓ Configuration downloaded and extracted${NC}"
}

preflight_secrets() {
  echo -e "${CYAN}Checking Secrets Manager access (optional)...${NC}"
  (
    set -e
    # If an encrypted token exists or a token/env is present, try to run the wizard now
    if [[ -f secrets/bws.token.age || -n "${BWS_ACCESS_TOKEN:-}" ]]; then
      echo -e "${CYAN}Running secrets wizard in live environment (this may prompt).${NC}"
      if command -v nix >/dev/null 2>&1; then
        nix shell nixpkgs#age nixpkgs#jq -c -- bash scripts/secrets-wizard.sh || true
      else
        bash scripts/secrets-wizard.sh || true
      fi
    else
      echo -e "${YELLOW}No BWS token or encrypted token found; skipping.${NC}"
    fi
  ) || echo -e "${YELLOW}Secrets preflight skipped/failed (will still work after reboot).${NC}"
}
run_apply() {
  # Interactive by default; set NONINTERACTIVE=1 externally only if desired.
  : "${HOST_NAME:=}"  # allow pre-seeding
  : "${BOOT_DISK:=}"
  ./apps/x86_64-linux/apply
  export USERNAME="david"
  echo -e "${GREEN}✓ Configuration complete${NC}"
}

run_disko() {
  nix --experimental-features "nix-command flakes" run github:nix-community/disko -- --mode disko ./modules/nixos/disk-config.nix
  echo -e "${GREEN}✓ Disk formatted and mounted${NC}"
}

prompt_bws() {
  echo -e "\n${CYAN}How would you like to access your GitHub token?${NC}"
  echo -e "1) I already have access via SSH and have the token"
  echo -e "2) I need to login with my Bitwarden password and 2FA"
  read -r -p "Enter your choice (1-2): " choice

  case "$choice" in
    1)
      echo -e "${CYAN}Please paste your existing Bitwarden Secrets Manager token:${NC}"
      read -r -p "Token: " BWS_ACCESS_TOKEN
      if [ -z "${BWS_ACCESS_TOKEN}" ]; then
        echo -e "${RED}No token provided${NC}"
        return 1
      fi
      export BWS_ACCESS_TOKEN
      ;;

    2)
      ensure_bw || {
        echo -e "${RED}Failed to ensure Bitwarden CLI is available${NC}"
        return 1
      }
      
      read -r -p "Enter your Bitwarden email: " BW_EMAIL
      read -r -s -p "Enter your master password: " BW_PASSWORD
      echo
      read -r -p "Enter your 2FA code: " BW_2FA
      
      echo -e "${CYAN}Logging into Bitwarden...${NC}"
      GITHUB_TOKEN=$(bw_get_token "$BW_EMAIL" "$BW_PASSWORD" "$BW_2FA")
      if [ $? -eq 0 ] && [ -n "$GITHUB_TOKEN" ]; then
        echo -e "${GREEN}✓ Successfully retrieved GitHub token${NC}"
        # Store the token for use by other functions
        echo "$GITHUB_TOKEN" > /tmp/github_token.tmp
        chmod 600 /tmp/github_token.tmp
      else
        echo -e "${RED}Failed to retrieve GitHub token${NC}"
        return 1
      fi
      ;;
      
    *)
      echo -e "${RED}Invalid choice${NC}"
      return 1
      ;;
  esac
}

setup_files() {
  mkdir -p /mnt/etc/nixos
  cp -r * /mnt/etc/nixos
  cd /mnt/etc/nixos
  echo -e "${GREEN}✓ Files copied to system${NC}"

  # Ensure a clean ~/nix git clone for the first boot
  mkdir -p /mnt/home/david
  if [ -d "/mnt/home/david/nix" ]; then
    rm -rf /mnt/home/david/nix
  fi

  # Set up GitHub authentication
  if [[ -n "${BWS_ACCESS_TOKEN:-}" ]]; then
    ensure_bws || {
      echo -e "${YELLOW}Failed to ensure bws command is available${NC}"
      return 1
    }
    
    # Get GitHub token from BWS
    echo -e "${CYAN}Fetching GitHub token from Bitwarden Secrets Manager...${NC}"
    GITHUB_TOKEN=$(bws_cmd secret get --field token "GitHub Token")
  elif [[ -f /tmp/github_token.tmp ]]; then
    # Get GitHub token from temporary file (from master password login)
    GITHUB_TOKEN=$(cat /tmp/github_token.tmp)
    rm -f /tmp/github_token.tmp  # Clean up
    
    if [[ -n "$GITHUB_TOKEN" ]]; then
      echo -e "${GREEN}✓ GitHub token retrieved successfully${NC}"
      
      # Use token for initial clone
      git clone --origin nyx --depth 1 --branch master "https://xlrinn:${GITHUB_TOKEN}@github.com/xlrinn/nix.git" /mnt/home/david/nix
      
      # Set up permanent auth via .netrc
      mkdir -p /mnt/home/david/.config/git
      cat > /mnt/home/david/.netrc <<EOF
machine github.com
login xlrinn
password ${GITHUB_TOKEN}
EOF
      chmod 600 /mnt/home/david/.netrc
      chown 1000:1000 /mnt/home/david/.netrc
      
      # Configure git to use credentials
      git -C /mnt/home/david/nix config credential.helper "store --file /home/david/.config/git/credentials"
      echo -e "${GREEN}✓ GitHub authentication configured${NC}"
    else
      echo -e "${YELLOW}Failed to get GitHub token, falling back to HTTPS clone${NC}"
      git clone --origin nyx --depth 1 --branch master https://github.com/xlrinn/nix.git /mnt/home/david/nix
    fi
  else
    echo -e "${YELLOW}No BWS token available, using HTTPS clone${NC}"
    git clone --origin nyx --depth 1 --branch master https://github.com/xlrinn/nix.git /mnt/home/david/nix
  fi

  # Minimal identity passthrough (optional)
  if [ -f /tmp/git_name.txt ]; then git -C /mnt/home/david/nix config user.name "$(cat /tmp/git_name.txt)"; fi
  if [ -f /tmp/git_email.txt ]; then git -C /mnt/home/david/nix config user.email "$(cat /tmp/git_email.txt)"; fi
  
  # Prefer SSH remote so pushes work once SSH keys are in place
  git -C /mnt/home/david/nix remote set-url nyx git@github.com:xlrinn/nix.git >/dev/null 2>&1 || true
  git -C /mnt/home/david/nix config --add remote.nyx.fetch "+refs/heads/*:refs/remotes/nyx/*" || true
  git -C /mnt/home/david/nix remote set-branches nyx '*' || true
  git -C /mnt/home/david/nix fetch nyx --prune --tags || true
  git -C /mnt/home/david/nix fetch nyx --unshallow >/dev/null 2>&1 || true
  chown -R 1000:1000 /mnt/home/david/nix
  chmod -R 755 /mnt/home/david/nix

  # Seed per-user git config so pushes are ready after first boot
  if [ -f /tmp/git_name.txt ] && [ -f /tmp/git_email.txt ]; then
    mkdir -p /mnt/home/david
    cat > /mnt/home/david/.gitconfig <<EOF
[user]
    name = $(cat /tmp/git_name.txt)
    email = $(cat /tmp/git_email.txt)
[pull]
    rebase = false
EOF
    chown 1000:1000 /mnt/home/david/.gitconfig
    chmod 600 /mnt/home/david/.gitconfig
  fi

  # Optionally pre-provision Bitwarden Secrets Manager token for first boot
  if [[ -n "${BWS_ACCESS_TOKEN:-}" ]]; then
    echo -e "${CYAN}Provisioning BWS token for first boot...${NC}"
    # Prefer encrypted token in repo using age via nix shell; fallback to private env file
    if [[ -n "${BWS_TOKEN_PASSPHRASE:-}" ]]; then
      chroot /mnt /bin/sh -lc "cd /home/david/nix && nix shell nixpkgs#age -c BWS_ACCESS_TOKEN='${BWS_ACCESS_TOKEN}' BWS_TOKEN_PASSPHRASE='${BWS_TOKEN_PASSPHRASE}' bash scripts/prepare-bws-token.sh" || {
        echo -e "${YELLOW}Failed to create encrypted token; falling back to ~/.secrets/bws.env${NC}"
        mkdir -p /mnt/home/david/.secrets
        printf "export BWS_ACCESS_TOKEN='%s'\n" "${BWS_ACCESS_TOKEN}" > /mnt/home/david/.secrets/bws.env
        chmod 600 /mnt/home/david/.secrets/bws.env
      }
    else
      mkdir -p /mnt/home/david/.secrets
      printf "export BWS_ACCESS_TOKEN='%s'\n" "${BWS_ACCESS_TOKEN}" > /mnt/home/david/.secrets/bws.env
      chmod 600 /mnt/home/david/.secrets/bws.env
    fi
  fi
}

install_nixos() {
  ARCH=$(uname -m)

  case "$ARCH" in
    x86_64)
      FLAKE_TARGET="x86_64-linux"
      ;;
    aarch64)
      FLAKE_TARGET="aarch64-linux"
      ;;
    *)
      echo -e "${RED}Unsupported architecture: $ARCH${NC}"
      exit 1
      ;;
  esac

  nixos-install --flake .#$FLAKE_TARGET --option max-jobs 1 --no-write-lock-file --no-root-passwd
  chmod -R 775 /mnt/etc/nixos
  
  # Set root and user passwords non-interactively
  echo "root:6!y2c87T" | chroot /mnt /nix/var/nix/profiles/system/sw/bin/chpasswd
  echo "david:6!y2c87T" | chroot /mnt /nix/var/nix/profiles/system/sw/bin/chpasswd
  
  echo -e "${GREEN}✓ NixOS installed successfully${NC}"
}

run_unlock() {
  if [[ "${RUN_UNLOCK:-1}" != "1" ]]; then
    echo -e "${YELLOW}Skipping Bitwarden setup (RUN_UNLOCK=${RUN_UNLOCK:-0}).${NC}"
    return
  fi

  if [[ -z "${BWS_ACCESS_TOKEN:-}" ]]; then
    echo -e "${CYAN}Please enter your Bitwarden access token to set up secrets:${NC}"
    read -r -p "BWS access token: " BWS_ACCESS_TOKEN
    export BWS_ACCESS_TOKEN
  fi

  if [[ -n "${BWS_ACCESS_TOKEN:-}" ]]; then
    mkdir -p /mnt/home/david/.secrets
    printf "export BWS_ACCESS_TOKEN='%s'\n" "${BWS_ACCESS_TOKEN}" > /mnt/home/david/.secrets/bws.env
    chmod 600 /mnt/home/david/.secrets/bws.env
    chown -R 1000:1000 /mnt/home/david/.secrets
    echo -e "${GREEN}✓ Bitwarden Secrets Manager token configured${NC}"
  fi
}

prompt_reboot() {
  echo -e "\e[1;32mRebooting in 5 seconds...\e[0m"
  sleep 5
  reboot
}

cleanup
check_installer
check_uefi_or_exit
download_config
run_apply
preflight_secrets
run_disko
prompt_bws
setup_files
install_nixos
run_unlock
cleanup
prompt_reboot 
