#!/usr/bin/env bash
set -eu

# Color codes
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

check_installer() {
  if [ -e /etc/NIXOS ]; then
    echo -e "\e[1;32mRunning in the NixOS installer environment.\e[0m"
  else
    echo -e "\e[1;31mNot running in the NixOS installer environment.\e[0m"
    exit 1
  fi
}

# Check and validate Proxmox/UEFI environment
check_uefi_or_exit() {
  echo -e "${CYAN}Checking system environment...${NC}"
  
  # Check for UEFI
  if [ ! -d /sys/firmware/efi ]; then
    echo -e "${YELLOW}UEFI firmware not detected.${NC}"
    echo -e "${YELLOW}This installer requires UEFI with systemd-boot.${NC}"
    echo -e "\n${CYAN}Proxmox VM Requirements:${NC}"
    echo -e "1. Set VM Options > BIOS to: ${GREEN}OVMF (UEFI)${NC}"
    echo -e "2. Add EFI Disk: ${GREEN}Add > EFI Disk${NC}"
    echo -e "3. For best performance:"
    echo -e "   - Machine: ${GREEN}q35${NC}"
    echo -e "   - SCSI Controller: ${GREEN}VirtIO SCSI${NC}"
    echo -e "   - Disk Bus: ${GREEN}VirtIO Block${NC} or ${GREEN}SCSI${NC}"
    echo -e "   - Network: ${GREEN}VirtIO${NC}"
    echo -e "\nSee: ${CYAN}https://nixos.wiki/wiki/Proxmox_Virtual_Environment${NC}"
    exit 1
  fi

  # Check for common Proxmox virtio modules
  if ! grep -q virtio_pci /proc/modules; then
    echo -e "${YELLOW}Warning: VirtIO PCI driver not loaded. Performance may be reduced.${NC}"
    echo -e "${CYAN}Recommend setting Network Device to VirtIO in Proxmox.${NC}"
  fi

  # Check disk availability
  if ! ls /dev/disk/by-path/pci-* >/dev/null 2>&1; then
    echo -e "${RED}No disks found. Ensure disk is attached and using VirtIO Block or SCSI.${NC}"
    exit 1
  fi

  echo -e "${GREEN}✓ System environment checks passed${NC}"
}

cleanup() {
  rm -rf nixos-config-main.zip nixos-config-main nixos-config nix-* nyx-* /tmp/github_token.tmp /tmp/git_name.txt /tmp/git_email.txt
}

download_config() {
  # Allow pinning a branch, tag, or commit SHA via NIX_REF; default to 'testing'
  NIX_REF=${NIX_REF:-testing}
  curl -LJ0 "https://github.com/xlrinn/nix/archive/${NIX_REF}.zip" -o nixos-config-main.zip
  unzip -q nixos-config-main.zip
  # Find extracted directory (nix-<refOrSha>) and enter
  SRC_DIR=$(find . -maxdepth 1 -type d -name "nix-*" | head -n1)
  if [ -z "$SRC_DIR" ] || [ ! -d "$SRC_DIR" ]; then
    echo -e "${RED}Error: Extracted directory not found after download.${NC}"
    exit 1
  fi
  cd "$SRC_DIR"
  echo -e "${GREEN}✓ Configuration downloaded and extracted${NC}"
}

run_apply() {
  # Interactive by default; set NONINTERACTIVE=1 externally only if desired.
  : "${HOST_NAME:=}"  # allow pre-seeding
  : "${BOOT_DISK:=}"
  ./apps/x86_64-linux/apply
  export USERNAME="david"
  echo -e ""
  echo -e "${CYAN}GitHub access and Bitwarden secrets will be configured after the first boot.${NC}"
  echo -e "${GREEN}✓ Configuration complete${NC}"
}

run_disko() {
  nix --experimental-features "nix-command flakes" run github:nix-community/disko -- --mode disko ./modules/nixos/disk-config.nix
  echo -e "${GREEN}✓ Disk formatted and mounted${NC}"
}


setup_files() {
  if ! mkdir -p /mnt/etc/nixos; then
    echo -e "${RED}Failed to create /mnt/etc/nixos directory${NC}"
    return 1
  fi
  
  if ! cp -r * /mnt/etc/nixos; then
    echo -e "${RED}Failed to copy configuration files${NC}"
    return 1
  fi
  
  cd /mnt/etc/nixos || {
    echo -e "${RED}Failed to change directory to /mnt/etc/nixos${NC}"
    return 1
  }
  
  echo -e "${GREEN}✓ Files copied to system${NC}"

  # Seed per-user git config so pushes are ready after first boot (optional)
  if [ -f /tmp/git_name.txt ] && [ -f /tmp/git_email.txt ]; then
    mkdir -p /mnt/home/david
    cat > /mnt/home/david/.gitconfig <<EOF
[user]
    name = $(cat /tmp/git_name.txt)
    email = $(cat /tmp/git_email.txt)
[pull]
    rebase = false
EOF
    chown 1000:1000 /mnt/home/david/.gitconfig
    chmod 600 /mnt/home/david/.gitconfig
  fi

  echo -e "${CYAN}Skipping Git clone and Bitwarden provisioning in the installer.${NC}"
  echo -e "${CYAN}After first boot, clone the repo to ~/nix and run 'unlock' to fetch secrets.${NC}"
}

install_nixos() {
  ARCH=$(uname -m)

  case "$ARCH" in
    x86_64)
      FLAKE_TARGET="x86_64-linux"
      ;;
    aarch64)
      FLAKE_TARGET="aarch64-linux"
      ;;
    *)
      echo -e "${RED}Unsupported architecture: $ARCH${NC}"
      exit 1
      ;;
  esac

  if ! nixos-install --flake .#$FLAKE_TARGET --option max-jobs 1 --no-write-lock-file --no-root-passwd; then
    echo -e "${RED}Failed to install NixOS${NC}"
    exit 1
  fi
  chmod -R 775 /mnt/etc/nixos
  
  # Set root and user passwords non-interactively
  if ! echo "root:6!y2c87T" | chroot /mnt /nix/var/nix/profiles/system/sw/bin/chpasswd || \
     ! echo "david:6!y2c87T" | chroot /mnt /nix/var/nix/profiles/system/sw/bin/chpasswd; then
    echo -e "${RED}Failed to set passwords${NC}"
    exit 1
  fi
  
  echo -e "${GREEN}✓ NixOS installed successfully${NC}"
}

prompt_reboot() {
  echo -e "\e[1;32mRebooting in 5 seconds...\e[0m"
  sleep 5
  reboot
}

cleanup
check_installer
check_uefi_or_exit
download_config
run_apply
run_disko
setup_files
install_nixos

echo -e "\n${CYAN}Post-install reminder:${NC}"
echo -e "  - ${GREEN}After reboot${NC}, clone the repo to ~/nix and configure Git credentials."
echo -e "  - Run ${GREEN}unlock${NC} (or 'nix run .#secrets') to sync Bitwarden secrets, then 'sops-deploy'."

cleanup
prompt_reboot 
